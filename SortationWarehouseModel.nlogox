    <monitor x="155" precision="17" y="1038" height="60" fontSize="11" width="149" display="Transfer Staging moves">moved-by-transfer</monitor>
    <monitor x="305" precision="17" y="1038" height="60" fontSize="11" width="137" display="%Staged by transfers">pct-moved-by-transfer</monitor>
    <monitor x="515" precision="17" y="975" height="60" fontSize="11" width="145" display="Max blocked">max-blocked-now</monitor>
    <monitor x="661" precision="17" y="975" height="60" fontSize="11" width="126" display="Mean blocked">mean-blocked-now</monitor>
