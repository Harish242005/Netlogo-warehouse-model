    <slider x="0" step="50" y="30" max="2000" width="360" display="inbound-pallets-left" height="54" min="0" direction="Horizontal" default="249" variable="inbound-pallets-left"></slider>
    <note x="0" y="0" backgroundDark="0" fontSize="20" width="160" markdown="false" height="29" textColorDark="-1" textColorLight="-1572864" backgroundLight="786588">RUN CONTROL</note>
    <slider x="524" step="1" y="599" max="50" width="250" display="target-loss-count" height="54" min="0" direction="Horizontal" default="4" variable="target-loss-count"></slider>
    <slider x="521" step="50" y="541" max="5000" width="250" display="deliveries-target" height="50" min="0" direction="Horizontal" default="200" variable="deliveries-target"></slider>
    <note x="506" y="490" backgroundDark="0" fontSize="20" width="217" markdown="false" height="60" textColorDark="-1" textColorLight="-6422273" backgroundLight="0">TARGET SETTINGS</note>
    <plot x="812" autoPlotX="true" yMax="10" autoPlotY="true" y="560" xMin="0" height="182" legend="true" xMax="10" yMin="0" width="331" display="Human Utilization">
      <setup></setup>
      <update></update>
      <pen interval="1" mode="0" display="working" color="-16116700" legend="true">
        <setup></setup>
        <update>plot count humans with [mstate != "resting"]
</update>
      </pen>
      <pen interval="1" mode="0" display="resting" color="-2674135" legend="true">
        <setup></setup>
        <update>plot count humans with [mstate = "resting"]</update>
      </pen>
      <pen interval="1" mode="0" display="carrying" color="-955883" legend="true">
        <setup></setup>
        <update>plot count humans with [carry?]</update>
      </pen>
    </plot>
    <plot x="1158" autoPlotX="true" yMax="10" autoPlotY="true" y="562" xMin="0" height="182" legend="true" xMax="10" yMin="0" width="341" display="Delivery progress">
      <setup></setup>
      <update></update>
      <pen interval="1" mode="0" display="delivered" color="-14136696" legend="true">
        <setup></setup>
        <update>plot deliveries</update>
      </pen>
      <pen interval="1" mode="0" display="eff-target" color="-2674135" legend="true">
        <setup></setup>
        <update>plot effective-delivery-target</update>
      </pen>
    </plot>
    <plot x="804" autoPlotX="true" yMax="10" autoPlotY="true" y="383" xMin="0" height="170" legend="true" xMax="10" yMin="0" width="342" display="Fleet status">
      <setup></setup>
      <update></update>
      <pen interval="1" mode="0" display="active" color="-15051147" legend="true">
        <setup></setup>
        <update>plot count active-movers</update>
      </pen>
      <pen interval="1" mode="0" display="charging" color="-13840069" legend="true">
        <setup></setup>
        <update>plot count (turtle-set inbound-trucks carriers transfer-cars) with [mstate = "charging"]</update>
      </pen>
      <pen interval="1" mode="0" display="broken-dead" color="-2674135" legend="true">
        <setup></setup>
        <update>plot count (turtle-set inbound-trucks carriers transfer-cars) with [member? mstate ["broken" "dead"]]</update>
      </pen>
    </plot>
    <plot x="1165" autoPlotX="true" yMax="10" autoPlotY="true" y="378" xMin="0" height="177" legend="true" xMax="10" yMin="0" width="340" display="WIP">
      <setup></setup>
      <update></update>
      <pen interval="1" mode="0" display="blue-items" color="-13345367" legend="true">
        <setup></setup>
        <update>plot sum [items] of blue-zone</update>
      </pen>
      <pen interval="1" mode="0" display="ready-items" color="-10899396" legend="true">
        <setup></setup>
        <update>plot sum [items] of ready-zone</update>
      </pen>
      <pen interval="1" mode="0" display="carrying" color="-2674135" legend="true">
        <setup></setup>
        <update>plot count (turtle-set inbound-trucks carriers transfer-cars) with [carry?]</update>
      </pen>
    </plot>
    <plot x="803" autoPlotX="true" yMax="10" autoPlotY="true" y="210" xMin="0" height="170" legend="false" xMax="10" yMin="0" width="336" display="Congestion">
      <setup></setup>
      <update></update>
      <pen interval="1" mode="0" display="mean-blocked" color="-10899396" legend="true">
        <setup></setup>
        <update>plot mean-blocked</update>
      </pen>
      <pen interval="1" mode="0" display="max-blocked" color="-2674135" legend="true">
        <setup></setup>
        <update>plot max-blocked</update>
      </pen>
    </plot>
    <plot x="1159" autoPlotX="true" yMax="100" autoPlotY="false" y="206" xMin="0" height="170" legend="true" xMax="10" yMin="0" width="344" display="Target progress (%)">
      <setup></setup>
      <update></update>
      <pen interval="1" mode="0" display="progress%" color="-2674135" legend="true">
        <setup></setup>
        <update>plot (ifelse-value (effective-delivery-target = 0) [0] [100 * deliveries / effective-delivery-target])</update>
      </pen>
      <pen interval="1" mode="0" display="100%" color="-7500403" legend="true">
        <setup></setup>
        <update>plot 100</update>
      </pen>
    </plot>
    <plot x="1155" autoPlotX="true" yMax="10" autoPlotY="true" y="17" xMin="0" height="188" legend="true" xMax="10" yMin="0" width="339" display="Battery">
      <setup></setup>
      <update></update>
      <pen interval="1" mode="0" display="mean-battery" color="-13345367" legend="true">
        <setup></setup>
        <update>if enable-battery? and any? (turtle-set inbound-trucks carriers transfer-cars) [ plot mean [battery] of (turtle-set inbound-trucks carriers transfer-cars) ]</update>
      </pen>
      <pen interval="1" mode="0" display="min-battery" color="-2674135" legend="true">
        <setup></setup>
        <update>if enable-battery? and any? (turtle-set inbound-trucks carriers transfer-cars) [ plot min [battery] of (turtle-set inbound-trucks carriers transfer-cars) ]</update>
      </pen>
    </plot>
    <plot x="802" autoPlotX="true" yMax="10" autoPlotY="true" y="27" xMin="0" height="183" legend="true" xMax="10" yMin="0" width="335" display="Tow &amp; queues">
      <setup></setup>
      <update></update>
      <pen interval="1" mode="0" display="broken-queue" color="-2674135" legend="true">
        <setup></setup>
        <update>plot length broken-queue</update>
      </pen>
      <pen interval="1" mode="0" display="dead-queue" color="-14796697" legend="true">
        <setup></setup>
        <update>plot length dead-queue</update>
      </pen>
      <pen interval="1" mode="0" display="tows-busy" color="-10899396" legend="true">
        <setup></setup>
        <update>plot (count repair-tows with [tstate != "idle"] + count charge-tows with [tstate != "idle"])</update>
      </pen>
    </plot>
